{
  "name": "@money-matters/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0",
    "drizzle-orm": "^0.39.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/uuid": "^9.0.8",
    "@money-matters/config": "workspace:*",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "4.7.1",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "generate": "dotenv-cli -e ../../.env.development -- drizzle-kit generate",
    "push": "dotenv-cli -e ../../.env.development -- drizzle-kit push",
    "seed": "pnpm build && dotenv-cli -e ../../.env.development -- tsx src/seed.ts",
    "typecheck": "tsc --noEmit",
    "build": "echo \"No build script yet\"",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "studio": "dotenv-cli -e ../../.env.development -- drizzle-kit studio"
  }
}
