{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["PORT", "DATABASE_URL", "INNGEST_EVENT_KEY", "INNGEST_SIGNING_KEY"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {"dependsOn": ["^test"]},
    "typecheck": {}
  }
}
